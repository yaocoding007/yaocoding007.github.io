---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
// import ToggleTheme from './ToggleTheme';
---

<header>
	<h2 class="title">
		<a href="/">{SITE_TITLE}</a>
	</h2>
	<nav class="nav">
		<!-- <HeaderLink href="/blog">博客!POSTS</HeaderLink> -->
		<HeaderLink href="/weekly">周刊!WEEKLY</HeaderLink>
		<HeaderLink href="/projects">项目!PROJECTS</HeaderLink>
		<!-- <HeaderLink href="/collection">深度好文!IN_DEPTH</HeaderLink> -->
		<HeaderLink href="/about">关于!ABOUT</HeaderLink>
	</nav>
	<!-- <ToggleTheme client:load /> -->
</header>
<style>
	header {
		position: fixed;
		top: 0;
		left: 0;
		z-index: 100;
		height: 60px;
		width: 100vw;
		padding: 0 50px;
		box-sizing: border-box;
		background-color: var(--theme-background);
		color: var(--theme-color);
		display: flex;
		align-items: center;
		margin: 0 auto;
		line-height: 80px;
	}
	.title {
		font-size: 24px;
	    color: var(--theme-color);
	}
	.nav {
		margin-left: auto;
	}
</style>
